#!/usr/bin/env bash
# Soothsayer setup — gstack-style. Clone the repo, run ./setup, add bin to PATH.
# v0.1 has no third-party dependencies, so setup only checks Python and the tests.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "Soothsayer setup"
if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is required (>= 3.10)." >&2
  exit 1
fi
python3 --version

echo "Running the gate-engine test suite..."
if python3 -m unittest discover -s "$HERE/tests" -t "$HERE" >/dev/null 2>&1; then
  echo "  tests: OK"
else
  echo "  tests: FAILED — see: python3 -m unittest discover -s tests -t ." >&2
  exit 1
fi

chmod +x "$HERE/bin/soothsayer"

# Seed a local config the first time (keys stay in the environment, never here).
mkdir -p "$HERE/.soothsayer"
if [ ! -f "$HERE/.soothsayer/config.json" ]; then
  cp "$HERE/config.example.json" "$HERE/.soothsayer/config.json"
  echo "  wrote .soothsayer/config.json (edit models; key comes from \$ANTHROPIC_API_KEY)"
fi

echo
echo "Config check:"
PYTHONPATH="$HERE" python3 -m soothsayer check --config "$HERE/.soothsayer/config.json" || \
  echo "  (a missing API key is fine for offline gate/demo use)"

echo
echo "Done. Add Soothsayer to your PATH:"
echo "    export PATH=\"$HERE/bin:\$PATH\""
echo "Or install cross-platform (Windows included):"
echo "    pip install -e ."
echo "Then try:"
echo "    soothsayer demo"
